<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme - Material 3 Dark -->
    <style name="Theme.AXTimer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ax_cyan</item>
        <item name="colorPrimaryVariant">@color/ax_cyan_dim</item>
        <item name="colorOnPrimary">@color/ax_deep_black</item>
        <item name="colorSecondary">@color/ax_purple</item>
        <item name="colorOnSecondary">@color/ax_text_primary</item>
        <item name="colorSurface">@color/ax_surface</item>
        <item name="colorOnSurface">@color/ax_text_primary</item>
        <item name="colorBackground">@color/ax_deep_black</item>
        <item name="colorOnBackground">@color/ax_text_primary</item>
        <item name="android:windowBackground">@color/ax_deep_black</item>
        <item name="android:statusBarColor">@color/ax_deep_black</item>
        <item name="android:navigationBarColor">@color/ax_deep_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Screen theme (no flicker) -->
    <style name="Theme.AXTimer.Splash" parent="Theme.AXTimer">
        <item name="android:windowBackground">@color/ax_deep_black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
